{
  "name": "ydah",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "netlify-lambda build functions/src && nuxt generate",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore .",
    "lint:style": "stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:style && yarn lint:prettier",
    "lintfix": "prettier --write --list-different . && yarn lint:js --fix && yarn lint:style --fix",
    "prepare": "husky install",
    "test": "jest",
    "test:ci": "jest --config jest.config.js --coverage",
    "lambda": "netlify-lambda serve functions/src"
  },
  "lint-staged": {
    "*.{js,vue}": "eslint --cache",
    "*.{css,scss,sass,html,vue}": "stylelint",
    "*.**": "prettier --check --ignore-unknown"
  },
  "dependencies": {
    "@nuxt/content": "^1.15.1",
    "@nuxtjs/axios": "^5.13.6",
    "@nuxtjs/date-fns": "^1.5.0",
    "core-js": "^3.30.2",
    "netlify-lambda": "^2.0.16",
    "nuxt": "^2.16.3",
    "prismjs": "^1.29.0",
    "vee-validate": "^3.4.15",
    "vue": "^2.7.14",
    "vue-server-renderer": "^2.7.14",
    "vue-template-compiler": "^2.7.14",
    "vuetify": "^2.6.15",
    "webpack": "4.46.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.22.5",
    "@nuxtjs/eslint-config": "^12.0.0",
    "@nuxtjs/eslint-module": "^4.0.2",
    "@nuxtjs/google-fonts": "^3.0.1",
    "@nuxtjs/storybook": "^4.3.2",
    "@nuxtjs/stylelint-module": "^5.0.1",
    "@nuxtjs/vuetify": "^1.12.3",
    "@vue/test-utils": "^2.4.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-jest": "^29.5.0",
    "codecov": "^3.8.3",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.15.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "lint-staged": "^13.2.2",
    "postcss": "^8.4.24",
    "postcss-html": "^1.5.0",
    "prettier": "^2.8.8",
    "stylelint": "^15.10.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard": "^33.0.0",
    "vue-jest": "^3.0.4",
    "yarn-audit-fix": "^9.3.12"
  }
}
