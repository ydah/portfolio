<%
  page_title = page['title'] || page[:title]
  page_description = page['description'] || page[:description]
  page_type = page['type'] || page[:type]
  page_ogimage = page['ogimage'] || page[:ogimage]
  page_path = page['path'] || ''
  page_slug = page['slug'] || page[:slug]
  page_url = if page_path.include?('content/posts/') && page_slug
               "/blog/posts/#{page_slug}/"
             elsif page_path.include?('content/activities/')
               '/activities/'
             else
               relative = page_path.sub(%r{^content/?}, '').sub(/\.md$/, '')
               relative = relative.sub(%r{(^|/)index$}, '\\1')
               relative = '/' if relative.empty?
               relative = "/#{relative}" unless relative.start_with?('/')
               relative = relative.end_with?('/') ? relative : "#{relative}/"
               relative
             end
%>
<!DOCTYPE html>
<html lang="<%= site['language'] || 'ja' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="format-detection" content="telephone=no">

  <title><%= page_title ? "#{page_title} - #{site['title']}" : site['title'] %></title>

  <meta name="description" content="<%= page_description || site['description'] %>">
  <meta name="keywords" content="ydah,software,engineer,portfolio,ruby">

  <meta property="og:site_name" content="<%= site['title'] %>">
  <meta property="og:type" content="<%= page_type || 'website' %>">
  <meta property="og:url" content="<%= site['url'] %><%= page_url %>">
  <meta property="og:title" content="<%= page_title || site['title'] %>">
  <meta property="og:description" content="<%= page_description || site['description'] %>">
  <% if page_ogimage %>
  <meta property="og:image" content="<%= site['url'] %>/assets/images/posts/<%= page_ogimage %>">
  <% else %>
  <meta property="og:image" content="<%= site['url'] %>/assets/images/ogp.png">
  <% end %>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@ydah_">

  <link rel="icon" type="image/x-icon" href="<%= asset_path('favicon.ico') %>">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css">

  <%= vite_client_tag %>
  <%= vite_js_tag 'src/main.js' %>
</head>
<body class="theme-dark min-h-screen flex flex-col">
  <header class="site-header border-b">
    <nav class="container mx-auto px-4 py-4 max-w-4xl">
      <a href="<%= url_for('/') %>" class="text-xl font-light text-white hover:text-gray-300" style="font-family: 'Audrey', sans-serif;">
        ydah.net
      </a>
    </nav>
  </header>

  <main class="container mx-auto px-4 py-8 max-w-4xl flex-1">
    <section class="mb-10">
      <h2 class="text-2xl font-light mb-4 border-b border-gray-600 pb-2" style="font-family: 'Audrey', sans-serif;">
        Yudai Takada (ydah)
      </h2>

      <p class="text-lg leading-relaxed mb-4">
        Yudai Takada is a CRuby committer and software engineer. As a software engineer,
        he has experience developing control and embedded applications, web backends, and web frontends.
        Additionally, He is also an experienced Scrum Master and has helped introduction of Scrum to teams.
      </p>

      <p class="text-lg leading-relaxed mb-4">
        He is engaged mainly in control and embedded software development at a software development company
        in Osaka 2015-2021. Currently, he works at
        <a href="https://andpad.co.jp/" class="underline hover:text-gray-300">ANDPAD Inc.</a>
        to re-architect Rails applications and solve cross-cutting technical issues.
      </p>

      <p>
        <a href="<%= url_for('/activities/') %>" class="underline hover:text-gray-300">→ More</a>
      </p>
    </section>

    <section>
      <h2 class="text-2xl font-light mb-4 border-b border-gray-600 pb-2" style="font-family: 'Audrey', sans-serif;">
        Links and Contacts
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% links = [
          { icon: 'mdi-gmail', url: 'mailto:t.yudai92@gmail.com', text: 't.yudai92@gmail.com' },
          { icon: 'mdi-rss', url: 'https://ydah.hatenablog.com/', text: 'ydah.hatenablog.com' },
          { icon: 'mdi-camera', url: url_for('/work/photo/'), text: 'ydah.net/work/photo' },
          { icon: 'mdi-chef-hat', url: url_for('/work/cook/'), text: 'ydah.net/work/cook' },
          { icon: 'mdi-github', url: 'https://github.com/ydah/', text: 'github.com/ydah' },
          { icon: 'mdi-presentation', url: 'https://speakerdeck.com/ydah', text: 'speakerdeck.com/ydah' },
          { icon: 'mdi-twitter', url: 'https://twitter.com/ydah_', text: 'twitter.com/ydah_' },
          { icon: 'mdi-mastodon', url: 'https://ruby.social/@ydah', text: 'ruby.social/@ydah' },
          { icon: 'mdi-cloud-circle', url: 'https://bsky.app/profile/ydah.bsky.social', text: 'ydah.bsky.social' },
          { icon: 'mdi-instagram', url: 'https://instagram.com/ydah__/', text: 'instagram.com/ydah__' },
        ] %>

        <% links.each do |link| %>
        <a href="<%= link[:url] %>" class="flex items-center gap-2 text-white hover:text-gray-300 underline">
          <span class="mdi <%= link[:icon] %> text-xl"></span>
          <%= link[:text] %>
        </a>
        <% end %>
      </div>
    </section>
  </main>

  <footer class="site-footer border-t mt-auto">
    <div class="container mx-auto px-4 py-4 max-w-4xl text-center text-gray-400">
      <small>
        &copy; <%= Time.now.year %> — ydah
      </small>
    </div>
  </footer>
</body>
</html>
